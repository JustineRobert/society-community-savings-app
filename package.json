{
  "name": "community-savings-app",
  "version": "1.0.0",
  "description": "Community Savings App - MERN Stack Application",
  "keywords": [
    "community",
    "savings",
    "group",
    "contribution",
    "loan"
  ],
  "homepage": "https://github.com/JustineRobert/society-community-savings-app#readme",
  "bugs": {
    "url": "https://github.com/JustineRobert/society-community-savings-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JustineRobert/society-community-savings-app.git"
  },
  "license": "ISC",
  "author": "Igune Justine Robert, TITech Community Capital LTD",
  "type": "module",
  "main": "community-savings-app-backend/server.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "concurrently \"npm --prefix community-savings-app-backend run dev\" \"npm --prefix community-savings-app-frontend start\"",
    "backend": "npm --prefix community-savings-app-backend run dev",
    "frontend": "npm --prefix community-savings-app-frontend start",
    "build": "npm --prefix community-savings-app-frontend run build",
    "test": "npm --prefix community-savings-app-backend test && npm --prefix community-savings-app-frontend test && jest --watchAll=false && jest",
    "install-all": "npm install && npm --prefix community-savings-app-backend install && npm --prefix community-savings-app-frontend install",
    "postman:test": "newman run postman/Community-auth-tests.postman_collection.json -e postman/Group-env.postman_environment.json --reporters cli,json --reporter-json-export postman/reports/newman-report.json",
    "seed-admin": "npm --prefix community-savings-app-backend run seed-admin",
    "seed-admin-cli": "node scripts/seed-admin-cli.js",
    "install:all": "bash scripts/setup.sh",
    "start:backend": "cd community-savings-app-backend && npm run start",
    "start:frontend": "cd community-savings-app-frontend && npm run dev",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "lint:frontend": "eslint community-savings-app-frontend/src",
    "lint:backend": "eslint community-savings-app-backend",
    "lint": "npm run lint:backend && npm run lint:frontend && eslint .",
    "lint:fix": "npm run lint:backend -- --fix && npm run lint:frontend -- --fix",
    "lint:all": "npm run lint --prefix community-savings-app-backend && npm run lint --prefix community-savings-app-frontend",
    "check:all": "npm run lint:all && npm run format:check",  
    "test:coverage": "jest --coverage",
    "test:providers": "jest tests/providers",  
    "test:ci": "jest --runInBand --coverage && jest --runInBand --ci",
    "format": "prettier --write \"community-savings-app-backend/**/*.{js,json,md}\" \"community-savings-app-frontend/src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"community-savings-app-backend/**/*.{js,json,md}\" \"community-savings-app-frontend/src/**/*.{js,jsx,json,css,md}\"",
    "quality": "npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "flatted": "^3.4.2",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jquery": "^4.0.0",
    "lodash": "^4.18.1",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "node-forge": "^1.4.0",
    "ping": "^1.0.0",
    "http-status": "^2.x.x",
    "prettier": "^3.8.3",
    "qs": "^6.15.2",
    "redis-cli": "^2.1.2",
    "underscore": "^1.13.8",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.6",
    "newman": "^6.2.2",
    "supertest": "^7.2.2",
    "vite": "^8.0.13"
  },
  "newman": {
    "collection": "postman/Community-auth-tests.postman_collection.json",
    "environment": "postman/Group-env.postman_environment.json"
  }
}
