# Environment: development, production, or staging
NODE_ENV=development

# Server Configuration
PORT=5000
MONGO_URI=mongodb://localhost:27017/community_savings
JWT_SECRET=supersecretkey
REDIS_URL=redis://localhost:6379
HOST=localhost

# Database Configuration
# MongoDB Connection String (SRV format recommended for MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/community-savings?retryWrites=true&w=majority

# Fallback MongoDB Connection String (Standard URI format)
# Used if SRV connection fails (e.g., DNS issues)
MONGO_URI_FALLBACK=mongodb://localhost:27017/community-savings

# JWT Configuration
# Secret keys for token signing (use strong random strings in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars

# CORS Configuration
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Email Configuration (if implementing email features)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@communitysavingsapp.com

# Logging Configuration
LOG_LEVEL=debug
LOG_DIR=./logs

# Session Configuration
SESSION_SECRET=your_session_secret_change_in_production

# Feature Flags
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PASSWORD_RESET=true
ENABLE_REFERRALS=true

# Redis (used for job queue, rate limiting, cache)
REDIS_URL=redis://localhost:6379

# Third-party Services (Optional)
# Stripe, PayPal, etc.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=


APP_NAME=TITech Community Capital LTD
FRONTEND_URL=https://app.titechcapital.com
API_URL=https://api.titechcapital.com


CRB_API_URL=https://your-crb-provider/api



MTN_ENVIRONMENT=production|sandbox
MTN_OAUTH_URL=https://api.mtn.com/v1/oauth/token
MTN_COLLECTIONS_URL=https://api.mtn.com/v1/collections
MTN_DISBURSEMENTS_URL=https://api.mtn.com/v1/disbursements
MTN_API_USER_ID=...
MTN_API_KEY=...
MTN_SUBSCRIPTION_KEY=...
MTN_PRIMARY_KEY=...            # for webhook signature verification if used
MTN_CLIENT_ID=...
MTN_CLIENT_SECRET=...
MTN_TOKEN_CACHE_TTL=300        # seconds
MTN_RETRY_MAX=5
MTN_RETRY_BASE_MS=300
IDEMPOTENCY_TTL=86400          # seconds


SEED_ADMIN_TENANT_ID=SYSTEM

SEED_ADMIN_FIRSTNAME=System

SEED_ADMIN_LASTNAME=Administrator

SEED_ADMIN_EMAIL=admin@titechcapital.com

SEED_ADMIN_PHONE=+256782397907

SEED_ADMIN_PASSWORD=ChangeMeImmediately123!

SEED_ADMIN_ROLE=super_admin

DEFAULT_TENANT_ID=SYSTEM

MONGO_URI=mongodb://localhost:27017/titech

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=titech
POSTGRES_USER=postgres

RETENTION_DAYS=30

S3_BUCKET=titech-backups-prod

AZURE_CONTAINER=https://storageaccount.blob.core.windows.net/backups


PORT=5000

DB_PORT=27017

REDIS_ENABLED=true

MOBILE_MONEY_PROVIDERS=mtn,airtel

JWT_ACCESS_SECRET=my-secret



