# Default: normalize text files to LF
* text=auto eol=lf

# Environment files
*.env text eol=lf
*.env.* text eol=lf

# Shell scripts
*.sh text eol=lf

# JavaScript / TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf

# Logs and lock files
*.log text eol=lf
*.lock text eol=lf

# Frontend build outputs (binary, no conversion)
dist/** binary
build/** binary

# Images and assets (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary